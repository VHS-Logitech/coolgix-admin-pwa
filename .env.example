# =============================================================================
# Copy to `.env` — `.env` is gitignored.
# =============================================================================

# --- Local (`npm run dev`) — app: http://localhost:5180 ---
VITE_DEV_PROXY_TARGET=http://127.0.0.1:5000
# VITE_DEV_USE_REMOTE_API=http://127.0.0.1:5000

# --- Production ---
# Default: same-origin /api (Vercel: vercel.json → v2). VITE_API_URL alone is ignored.
# Cross-origin only if API CORS allows your site — set both:
# VITE_API_URL=https://v2.coolgix.com
# VITE_USE_DIRECT_API=1
